{
  "name": "@cobos/tokens",
  "version": "0.1.0",
  "description": "Design tokens for Cobos UI — CSS variables and JSON.",
  "author": "Ernesto Cobos <ernesto@cobos.io>",
  "license": "MIT",
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tokens.css": "./dist/tokens.css",
    "./tokens.light.css": "./dist/tokens.light.css",
    "./tokens.dark.css": "./dist/tokens.dark.css",
    "./tokens.json": "./dist/tokens.json",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ErnestoCobos/cobos-ui.git",
    "directory": "packages/tokens"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean && node scripts/build.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
