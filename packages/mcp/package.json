{
  "name": "@cobos/mcp",
  "version": "0.1.0",
  "description": "Model Context Protocol server that exposes the Cobos UI design system to AI agents.",
  "author": "Ernesto Cobos <ernesto@cobos.io>",
  "license": "MIT",
  "type": "module",
  "homepage": "https://ui.cobos.io",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "cobos-ui",
    "design-system",
    "react"
  ],
  "bin": {
    "cobos-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "registry"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ErnestoCobos/cobos-ui.git",
    "directory": "packages/mcp"
  },
  "scripts": {
    "build": "node scripts/copy-registry.mjs && tsup",
    "copy-registry": "node scripts/copy-registry.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.6",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
